<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.LogBook" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/black</item>

        <item name="alertDialogTheme">@style/CustomDialogStyle</item>
        <item name="materialAlertDialogTheme">@style/CustomDialogStyle</item>
    </style>

    <style name="Theme.LogBook" parent="Base.Theme.LogBook" />

    <style name="CustomDialogStyle" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:background">@drawable/dialog_background</item>
        <item name="backgroundTint">@color/background_color</item>

        <item name="android:textColorPrimary">@color/text_color</item>

        <item name="colorPrimary">@color/text_color</item>
        <item name="colorOnPrimary">@color/background_color</item>

        <item name="buttonBarPositiveButtonStyle">@style/CustomDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/CustomDialogButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/CustomDialogButton</item>

        <item name="shapeAppearanceOverlay">@style/DialogCorners</item>
    </style>

    <style name="CustomDialogButton" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_color</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="DialogCorners" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Theme.App.Starting" parent="Base.Theme.LogBook">
        <!-- Set the splash screen background color -->
        <item name="windowSplashScreenBackground">@color/background_color</item>

        <!-- Set the splash screen icon (center) -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>

        <!-- Optional: Set icon background color -->
        <item name="windowSplashScreenIconBackgroundColor">@color/background_color</item>
    </style>

</resources>