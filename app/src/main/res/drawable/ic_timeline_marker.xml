<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/text_color" />
            <size
                android:width="22dp"
                android:height="22dp" />
        </shape>
    </item>
    <!-- Inner circle -->
    <item
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp"
        android:top="4dp">
        <shape android:shape="oval">
            <solid android:color="@color/background_color" />
        </shape>
    </item>
    <!-- Center dot -->
    <item
        android:bottom="7dp"
        android:left="7dp"
        android:right="7dp"
        android:top="7dp">
        <shape android:shape="oval">
            <solid android:color="@color/background_color" />
        </shape>
    </item>
</layer-list>